// .vscode/launch.json
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Game: Run Integrated Debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "game.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Python: Debug Pytest Tests",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "purpose": ["debug-test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "SDL_VIDEODRIVER": "dummy"
      },
      "justMyCode": false
    }
  ]
}