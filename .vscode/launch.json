{
  // VS Code debug configurations for the refactored project.
  // Open the Proj folder itself as the workspace root, then press F5.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Game: Run Integrated Debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "game.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Tests: Debug Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-q"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "SDL_VIDEODRIVER": "dummy"
      },
      "justMyCode": false
    },
    {
      "name": "Tests: Debug All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "-q"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "SDL_VIDEODRIVER": "dummy"
      },
      "justMyCode": false
    }
  ]
}
